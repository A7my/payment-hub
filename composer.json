{
    "name": "a7my/payment-hub",
    "description": "Enterprise-grade provider-agnostic payment framework for Laravel 12+",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "payment",
        "payment-gateway",
        "payment-framework",
        "stripe",
        "paypal",
        "paymob",
        "myfatoorah"
    ],
    "authors": [
        {
            "name": "Mifatoyeh",
            "email": "dev@mifatoyeh.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "stripe/stripe-php": "^20.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "innmind/black-box": "^5.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Mifatoyeh\\LaravelPaymentFramework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mifatoyeh\\LaravelPaymentFramework\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mifatoyeh\\LaravelPaymentFramework\\Providers\\PaymentServiceProvider"
            ],
            "aliases": {
                "Payment": "Mifatoyeh\\LaravelPaymentFramework\\Facades\\Payment"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}